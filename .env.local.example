# Copy to .env.local and fill in the real values.
# Real values live in the Vercel dashboard: Project → Settings → Environment Variables.
# Easiest: run `vercel env pull .env.local` after `vercel link`.

# Required for /api/login + /api/me (always)
SESSION_SECRET=
WORKSHOP_PASSWORD=

# Required for Redis-backed progress (always)
REDIS_URL=

# Vercel KV (auto-populated by `vercel env pull` when using Vercel Marketplace KV)
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Admin panel + Listen Labs integration (optional for local dev)
ADMIN_PASSWORD=
ANTHROPIC_API_KEY=
LISTEN_LABS_API_KEY=
LISTEN_LABS_STUDY_ID=
